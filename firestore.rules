rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} { 
      allow read, write: if false; 
    }

    // Auth Helpers
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn(); }
    function isOwner(userId) { return isVerified() && request.auth.uid == userId; }

    // Request evaluation helpers
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Role helpers
    function isAdmin() {
      // Allow the original platform dev or anyone whose email is explicitly admin@protocol.net
      return isSignedIn() && (request.auth.token.email == 'admin@protocol.net' || request.auth.token.email == 'syaswanthkumar66@gmail.com');
    }

    function isValidUserConfig(data) {
       return data.keys().hasAll(['id', 'email', 'username', 'displayName']) &&
        data.id is string && data.id.size() <= 128 &&
        data.email is string && data.email.size() <= 128 &&
        data.username is string && data.username.size() <= 128 &&
        data.displayName is string && data.displayName.size() <= 128 &&
        data.id == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if isVerified();

      allow create: if isOwner(userId) &&
        isValidId(userId) &&
        isValidUserConfig(incoming()) &&
        incoming().keys().size() <= 10;
        
      allow update: if isOwner(userId) &&
        isValidId(userId) &&
        isValidUserConfig(incoming()) && (
           isAdmin() || incoming().diff(existing()).affectedKeys().hasOnly(['username', 'displayName', 'avatar', 'description'])
        );
    }

    function isValidFriendRequest(data) {
       return data.keys().hasAll(['fromUserId', 'toUserId', 'createdAt', 'status']) &&
         data.fromUserId is string && data.fromUserId.size() <= 128 &&
         data.fromUserId == request.auth.uid &&
         data.toUserId is string && data.toUserId.size() <= 128 &&
         data.createdAt == request.time &&
         data.status == 'pending';
    }

    match /friendRequests/{requestId} {
      allow read: if isVerified() && (resource.data.toUserId == request.auth.uid || resource.data.fromUserId == request.auth.uid);
      allow create: if isVerified() && isValidId(requestId) && isValidFriendRequest(incoming());
      allow delete: if isVerified() && (existing().fromUserId == request.auth.uid || existing().toUserId == request.auth.uid);
      allow update: if isVerified() && (existing().toUserId == request.auth.uid || existing().fromUserId == request.auth.uid) && incoming().diff(existing()).affectedKeys().hasOnly(['status']);
    }
  }
}
