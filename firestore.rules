rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} { 
      allow read, write: if false; 
    }

    // Auth Helpers
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn(); }
    function isOwner(userId) { return isVerified() && request.auth.uid == userId; }

    function incoming() { return request.resource.data; }

    match /test/connection {
      allow read: if true;
    }

    match /users/{userId} {
      allow read: if isVerified();
      allow write: if isVerified() && request.auth.uid == userId;
    }

    match /pushSubscriptions/{userId} {
      allow read, write: if isVerified() && request.auth.uid == userId;
    }

    match /offline_messages/{messageId} {
      allow create: if isVerified() && (incoming().senderId == request.auth.uid || incoming().from == request.auth.uid);
      allow read, delete: if isVerified() && (resource == null || resource.data.to == request.auth.uid || resource.data.senderId == request.auth.uid);
    }

    match /friendRequests/{requestId} {
      allow create: if isVerified() && incoming().fromUserId == request.auth.uid;
      allow read, update, delete: if isVerified() && (resource == null || resource.data.toUserId == request.auth.uid || resource.data.fromUserId == request.auth.uid);
    }

    match /notifications/{notificationId} {
      allow create: if isVerified();
      allow read, update, delete: if isVerified() && (resource == null || resource.data.recipientId == request.auth.uid || resource.data.senderId == request.auth.uid);
    }
  }
}
